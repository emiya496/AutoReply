# DeepSeek API Key（在 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 博主定位（影响AI回复的风格和内容方向）
# 示例：美食博主、旅行博主、穿搭博主、健身博主、数码博主
BLOGGER_PERSONA=个人博主

# 回复风格
# 示例：友善热情、专业干练、幽默风趣、温柔知性
REPLY_STYLE=友善热情

# 自动发布模式（true=直接发布不询问，false=每条回复需要人工确认）
AUTO_REPLY=false

# 使用的浏览器：chrome（系统Chrome）或 msedge（系统Edge）
BROWSER=chrome

# 每条回复之间的延时范围（秒）- 建议15~45，过快会触发小红书灰评屏蔽
DELAY_MIN=15
DELAY_MAX=45

# 每次运行最多回复条数（防灰评，剩余的下次再跑）
MAX_REPLIES_PER_SESSION=3
